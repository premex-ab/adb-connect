# Reference systemd user unit for adb-connect. The standard `adb-connect remote setup`
# command generates a similar unit at ~/.config/systemd/user/adb-connect-server.service.
# Use this template only if you want to install the unit manually or tweak it.
#
# Place at ~/.config/systemd/user/adb-connect-server.service then:
#     systemctl --user daemon-reload
#     systemctl --user enable --now adb-connect-server.service

[Unit]
Description=adb-connect remote daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=%h/.local/bin/adb-connect daemon
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
